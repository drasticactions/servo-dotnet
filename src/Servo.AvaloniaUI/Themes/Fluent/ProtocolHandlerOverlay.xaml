<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:servo="using:Servo.AvaloniaUI">

  <ControlTheme x:Key="{x:Type servo:ProtocolHandlerOverlay}" TargetType="servo:ProtocolHandlerOverlay">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Panel Name="PART_Backdrop" Background="#80000000" />

          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  BorderBrush="{DynamicResource SystemControlTransientBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource OverlayCornerRadius}"
                  Padding="24"
                  MinWidth="340"
                  MaxWidth="420"
                  BoxShadow="0 4 16 #50000000">
            <StackPanel>
              <TextBlock Text="Protocol Handler Request"
                         FontWeight="SemiBold"
                         FontSize="16"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                         Margin="0,0,0,12" />

              <TextBlock Text="{TemplateBinding PromptText}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                         Margin="0,0,0,16" />

              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Name="PART_DenyButton"
                        Content="Deny"
                        MinWidth="80" />
                <Button Name="PART_AllowButton"
                        Content="Allow"
                        MinWidth="80"
                        Margin="8,0,0,0" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
