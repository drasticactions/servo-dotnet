<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:servo="using:Servo.AvaloniaUI">

  <ControlTheme x:Key="{x:Type servo:PromptOverlay}" TargetType="servo:PromptOverlay">
    <Setter Property="Template">
      <ControlTemplate>
        <Panel>
          <Panel Name="PART_Backdrop" Background="#80000000" />

          <Border HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                  BorderBrush="{DynamicResource SystemControlTransientBorderBrush}"
                  BorderThickness="1"
                  CornerRadius="{DynamicResource OverlayCornerRadius}"
                  Padding="24"
                  MinWidth="340"
                  MaxWidth="420"
                  BoxShadow="0 4 16 #50000000">
            <StackPanel>
              <TextBlock Text="{TemplateBinding Message}"
                         TextWrapping="Wrap"
                         Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                         Margin="0,0,0,12" />

              <TextBox Name="PART_InputBox"
                       Margin="0,0,0,16" />

              <StackPanel Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Name="PART_CancelButton"
                        Content="Cancel"
                        MinWidth="80"
                        IsCancel="True" />
                <Button Name="PART_OkButton"
                        Content="OK"
                        MinWidth="80"
                        Margin="8,0,0,0"
                        IsDefault="True" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Panel>
      </ControlTemplate>
    </Setter>
  </ControlTheme>

</ResourceDictionary>
